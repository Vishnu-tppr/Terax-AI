# Terax AI Flutter app local environment
# Copy this file to .env if you need a fresh local config.
# Only put client-safe values here. Do not put Supabase service-role secrets in this file.

# Backend URL used by the Flutter app.
# Desktop/iOS simulator: http://localhost:8000
# Android emulator:     http://10.0.2.2:8000
# Physical device:      http://YOUR_COMPUTER_IP:8000
BACKEND_BASE_URL=http://localhost:8000

# Optional AI key used by the client app.
GEMINI_API_KEY=CHANGE_ME

# Required for native Google sign-in.
# GOOGLE_WEB_CLIENT_ID should be the Google OAuth Web client ID configured in Supabase.
# GOOGLE_IOS_CLIENT_ID is only needed for iOS/macOS builds.
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=

# Optional Twilio values used by the local Flutter SMS service.
# Leave blank if you are not using real SMS from the client app.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional legacy backend API key. The new Python auth backend does not require this.
CLIENT_API_KEY=
