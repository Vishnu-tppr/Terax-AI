APP_NAME=Terax AI Supabase Backend
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000
# Optional. Only used by browser clients; Flutter mobile apps do not rely on CORS.
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# For mobile password reset deep linking.
SUPABASE_PASSWORD_RESET_REDIRECT=teraxai://reset-password
